---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase.js';

export async function getStaticPaths() {
  const { data: ejercicios } = await supabase.from('ejercicios').select('id');
  return (ejercicios ?? []).map((ej) => ({
    params: { id: ej.id.toString() },
  }));
}

const { id } = Astro.params;

const { data: ejercicio } = await supabase
  .from('ejercicios')
  .select(`*, subtemas(id, titulo, orden, temas(id, titulo, orden))`)
  .eq('id', id)
  .single();

if (!ejercicio) return Astro.redirect('/');

const cfg     = ejercicio.configuracion_ui ?? {};
const tipo    = ejercicio.tipo_ejercicio;
const tipoStr = tipo;
const subtema = ejercicio.subtemas;
const tema    = subtema?.temas;

// ── Helpers ────────────────────────────────────────────────────────────────────
function esc(s: string): string {
  return s
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// Colorea sintaxis sobre texto YA escapado
function syn(s: string): string {
  return s
    .replace(/\b(int|float|double|char|bool|void|const|auto|String|byte|short|long|unsigned|return|if|else|while|for|constexpr|static_cast|uint8_t|int16_t|uint32_t)\b/g,'<span class="sk">$1</span>')
    .replace(/\b(true|false|nullptr|NULL)\b/g,'<span class="sl">$1</span>')
    .replace(/(\/\/[^\n]*)/g,'<span class="sc">$1</span>')
    .replace(/(&quot;[^&]*&quot;)/g,'<span class="ss">$1</span>')
    .replace(/\b(\d+\.?\d*f?)\b/g,'<span class="sn">$1</span>');
}

// ── COMPLETAR ESPACIOS ─────────────────────────────────────────────────────────
// Divide por ___INPUT___, colorea cada parte por separado, inserta el input real en medio
function buildCompletarHTML(codigo: string): string {
  const INPUT_TAG = `<input id="inp-completar" type="text" autocomplete="off" spellcheck="false" placeholder="???" class="inline-input" />`;
  return codigo.split('\n').map(linea => {
    if (linea.includes('___INPUT___')) {
      const partes = linea.split('___INPUT___');
      const html = partes.map((p, i) =>
        syn(esc(p)) + (i < partes.length - 1 ? INPUT_TAG : '')
      ).join('');
      return `<div class="code-line">${html}</div>`;
    }
    return `<div class="code-line">${syn(esc(linea))}</div>`;
  }).join('');
}

// ── ARRASTRAR BLOQUES ──────────────────────────────────────────────────────────
// Divide cada línea por los tokens ___DROP_N___, inserta drop-zones reales
function buildArrastrarHTML(codigo: string): string {
  return codigo.split('\n').map(linea => {
    // encontrar todos los tokens DROP en esta línea
    const TOKEN = /___DROP_(\d+)___/g;
    let match;
    let lastIdx = 0;
    let parts = '';
    let found = false;
    TOKEN.lastIndex = 0;
    while ((match = TOKEN.exec(linea)) !== null) {
      found = true;
      const before = linea.slice(lastIdx, match.index);
      const dropN  = match[1];
      if (before) parts += syn(esc(before));
      parts += `<span class="drop-zone" data-drop="${dropN}">arrastra aquí</span>`;
      lastIdx = TOKEN.lastIndex;
    }
    if (found) {
      const after = linea.slice(lastIdx);
      if (after) parts += syn(esc(after));
      return `<div class="code-line">${parts}</div>`;
    }
    return `<div class="code-line">${syn(esc(linea))}</div>`;
  }).join('');
}

// ── SELECCIÓN MÚLTIPLE ─────────────────────────────────────────────────────────
function buildSeleccionHTML(codigo: string): string {
  const SELECT_TAG = `<span class="select-placeholder" id="select-chosen">▼ elegir</span>`;
  return codigo.split('\n').map(linea => {
    if (linea.includes('___SELECT___')) {
      const partes = linea.split('___SELECT___');
      const html = partes.map((p, i) =>
        syn(esc(p)) + (i < partes.length - 1 ? SELECT_TAG : '')
      ).join('');
      return `<div class="code-line">${html}</div>`;
    }
    return `<div class="code-line">${syn(esc(linea))}</div>`;
  }).join('');
}

// ── Meta de tipos ──────────────────────────────────────────────────────────────
const tipoMeta: Record<string, { label: string; icon: string; color: string; desc: string }> = {
  completar_espacios: { label:'Completar espacios', icon:'✏️', color:'blue',   desc:'Escribe el valor exacto que completa el código. Respeta mayúsculas y espacios.' },
  arrastrar_bloques:  { label:'Arrastrar bloques',  icon:'🧩', color:'cyan',   desc:'Arrastra cada bloque desde la paleta inferior hasta la zona punteada que le corresponde en el código.' },
  seleccion_multiple: { label:'Selección múltiple', icon:'☑️', color:'purple', desc:'Haz clic en la opción correcta de la lista inferior. Aparecerá en el hueco del código.' },
  ordenar_lineas:     { label:'Ordenar líneas',     icon:'↕️', color:'green',  desc:'Arrastra las líneas hacia arriba o abajo hasta que el flujo lógico del programa sea correcto.' },
  detectar_bug:       { label:'Caza de Bugs',       icon:'🐛', color:'red',    desc:'Lee el código con atención. Haz clic en la línea exacta que contiene el error lógico.' },
};
const meta = tipoMeta[tipo] ?? { label: tipo, icon:'📝', color:'blue', desc:'' };

const cfgJSON = JSON.stringify(cfg);
---

<Layout title={`${ejercicio.titulo} — RoboLearn`}>
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700;800&display=swap');

  :root {
    --bg:       #0d1117;
    --card:     #161b22;
    --inner:    #0b0f17;
    --b0:       rgba(255,255,255,0.07);
    --b1:       rgba(255,255,255,0.13);
    --blue:     #3b82f6;
    --blue-l:   #60a5fa;
    --blue-d:   rgba(59,130,246,0.12);
    --cyan:     #22d3ee;
    --green:    #4ade80;
    --yellow:   #facc15;
    --purple:   #a78bfa;
    --red:      #f87171;
    --t1:       #f1f5f9;
    --t2:       #94a3b8;
    --t3:       #64748b;
    --mono:     'JetBrains Mono', monospace;
    --sans:     'Inter', sans-serif;
  }

  *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
  html { scroll-behavior:smooth; }
  body { background:var(--bg); color:var(--t1); font-family:var(--sans); line-height:1.6; min-height:100vh; overflow-x:hidden; }

  /* ── Nav ── */
  .topnav {
    position:sticky; top:0; z-index:50;
    background:rgba(13,17,23,0.92); backdrop-filter:blur(16px);
    border-bottom:1px solid var(--b0);
  }
  .topnav-inner {
    max-width:1100px; margin:0 auto; padding:0 1.5rem; height:56px;
    display:flex; align-items:center; justify-content:space-between; gap:1rem;
  }
  .logo { display:flex; align-items:center; gap:0.6rem; text-decoration:none; }
  .logo-icon {
    width:30px; height:30px; background:var(--blue); border-radius:7px;
    display:flex; align-items:center; justify-content:center; font-size:0.95rem;
    box-shadow:0 0 14px rgba(59,130,246,0.35); flex-shrink:0;
  }
  .logo-name { font-weight:800; font-size:1.05rem; letter-spacing:-0.03em; color:var(--t1); }
  .logo-name span { color:var(--blue-l); }
  .breadcrumb {
    display:flex; align-items:center; gap:0.4rem;
    font-family:var(--mono); font-size:0.7rem; color:var(--t3); overflow:hidden;
  }
  .breadcrumb a { color:var(--t3); text-decoration:none; transition:color .2s; white-space:nowrap; }
  .breadcrumb a:hover { color:var(--blue-l); }
  .bc-sep { color:var(--t3); opacity:0.4; }
  .bc-cur { color:var(--t2); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:180px; }

  /* ── Page grid ── */
  .page-grid {
    max-width:1100px; margin:0 auto; padding:1.75rem 1.5rem 5rem;
    display:grid; grid-template-columns:1fr; gap:1.25rem;
  }
  @media (min-width:900px) {
    .page-grid { grid-template-columns:1fr 330px; align-items:start; }
    .ex-header  { grid-column:1 / -1; }
  }

  /* ── Header ejercicio ── */
  .ex-header {
    background:var(--card); border:1px solid var(--b0); border-radius:14px;
    padding:1.6rem 1.9rem; position:relative; overflow:hidden;
  }
  .ex-header::before {
    content:''; position:absolute; top:0; left:0; right:0; height:1px;
    background:linear-gradient(90deg,transparent,rgba(255,255,255,0.07),transparent);
  }
  .ex-badges { display:flex; align-items:center; gap:0.45rem; flex-wrap:wrap; margin-bottom:0.55rem; }
  .badge {
    font-family:var(--mono); font-size:0.63rem; font-weight:600;
    letter-spacing:0.07em; padding:0.2rem 0.6rem; border-radius:100px;
  }
  .badge-mod    { color:var(--blue-l); background:rgba(59,130,246,0.1);  border:1px solid rgba(59,130,246,0.22); }
  .badge-sub    { color:var(--t3);     background:rgba(255,255,255,0.04); border:1px solid var(--b1); }
  .badge-blue   { color:var(--blue-l); background:rgba(59,130,246,0.1);  border:1px solid rgba(59,130,246,0.25); }
  .badge-cyan   { color:var(--cyan);   background:rgba(34,211,238,0.08); border:1px solid rgba(34,211,238,0.22); }
  .badge-green  { color:var(--green);  background:rgba(74,222,128,0.08); border:1px solid rgba(74,222,128,0.22); }
  .badge-purple { color:var(--purple); background:rgba(167,139,250,0.08);border:1px solid rgba(167,139,250,0.22); }
  .badge-red    { color:var(--red);    background:rgba(248,113,113,0.08);border:1px solid rgba(248,113,113,0.22); }

  .ex-title { font-size:clamp(1.4rem,3vw,2rem); font-weight:800; letter-spacing:-0.03em; color:var(--t1); line-height:1.15; }
  .ex-mision {
    display:flex; gap:0.8rem; align-items:flex-start;
    background:rgba(59,130,246,0.05); border:1px solid rgba(59,130,246,0.17);
    border-left:3px solid var(--blue); border-radius:0 10px 10px 0;
    padding:0.9rem 1.1rem; margin-top:1rem;
  }
  .ex-mision-icon { font-size:1rem; flex-shrink:0; margin-top:2px; }
  .mision-label {
    font-family:var(--mono); font-size:0.6rem; letter-spacing:0.12em;
    text-transform:uppercase; color:var(--blue-l); margin-bottom:0.25rem;
  }
  .mision-text { font-size:0.9rem; color:var(--t2); line-height:1.7; }

  /* ── Panel genérico ── */
  .panel {
    background:var(--card); border:1px solid var(--b0); border-radius:14px;
    overflow:hidden;
  }
  .panel-hdr {
    display:flex; align-items:center; justify-content:space-between;
    padding:0.55rem 1rem; background:rgba(255,255,255,0.022);
    border-bottom:1px solid var(--b0);
  }
  .panel-lang {
    font-family:var(--mono); font-size:0.66rem;
    letter-spacing:0.1em; text-transform:uppercase; color:var(--t3);
  }
  .dots { display:flex; gap:5px; }
  .dot  { width:8px; height:8px; border-radius:50%; }
  .dr{background:#ef4444;} .dy{background:#f59e0b;} .dg{background:#22c55e;}

  /* ── Cuerpo de código ── */
  .code-body {
    padding:1.2rem 1.35rem; font-family:var(--mono); font-size:0.85rem;
    line-height:1.9; overflow-x:auto; min-height:100px;
    counter-reset:ln;
  }
  .code-line {
    display:block; white-space:pre; counter-increment:ln;
    padding-left:3rem; position:relative;
  }
  .code-line::before {
    content:counter(ln); position:absolute; left:0; width:2.3rem;
    text-align:right; color:var(--t3); font-size:0.73rem;
    padding-right:0.65rem; user-select:none; line-height:1.9;
  }
  /* Syntax tokens */
  .sk{color:#c084fc;} .sl{color:#86efac;} .sc{color:#475569;} .ss{color:#fde68a;} .sn{color:#86efac;}

  /* ── Input inline (completar) ── */
  .inline-input {
    display:inline-block;
    background:rgba(59,130,246,0.1);
    border:none; border-bottom:2px solid rgba(59,130,246,0.5);
    color:var(--blue-l); font-family:var(--mono); font-size:0.85rem;
    width:110px; padding:0 0.3rem 0.1rem;
    outline:none; text-align:center;
    transition:border-color .2s, background .2s;
    border-radius:3px 3px 0 0; vertical-align:baseline;
  }
  .inline-input:focus { border-bottom-color:var(--blue); background:rgba(59,130,246,0.18); }
  .inline-input.ok  { border-bottom-color:var(--green); color:var(--green); }
  .inline-input.err { border-bottom-color:var(--red);   color:var(--red);   }

  /* ── Drop zones (arrastrar) ── */
  .drop-zone {
    display:inline-block; min-width:80px; padding:0.05rem 0.55rem;
    background:rgba(34,211,238,0.06); border:1.5px dashed rgba(34,211,238,0.3);
    border-radius:5px; color:var(--t3); font-size:0.78rem; font-style:italic;
    transition:all .18s; vertical-align:baseline; cursor:default;
  }
  .drop-zone.over   { background:rgba(34,211,238,0.18); border-color:var(--cyan); color:var(--cyan); }
  .drop-zone.filled { background:rgba(34,211,238,0.1);  border-style:solid; border-color:rgba(34,211,238,0.4); color:var(--cyan); font-style:normal; }
  .drop-zone.ok     { background:rgba(74,222,128,0.1);  border-color:var(--green); color:var(--green); }
  .drop-zone.err    { background:rgba(248,113,113,0.1); border-color:var(--red);   color:var(--red); }

  /* Paleta de bloques */
  .blocks-palette {
    display:flex; flex-wrap:wrap; gap:0.5rem;
    padding:0.9rem 1.1rem; border-top:1px solid var(--b0);
    background:rgba(0,0,0,0.15);
  }
  .chip {
    font-family:var(--mono); font-size:0.8rem; font-weight:600;
    color:var(--cyan); background:rgba(34,211,238,0.08);
    border:1px solid rgba(34,211,238,0.25); border-radius:7px;
    padding:0.32rem 0.8rem; cursor:grab; user-select:none; transition:all .18s;
  }
  .chip:hover  { background:rgba(34,211,238,0.18); transform:translateY(-1px); }
  .chip.used   { opacity:0.25; pointer-events:none; }

  /* ── Select placeholder ── */
  .select-placeholder {
    display:inline-block; background:rgba(167,139,250,0.1);
    border:1.5px dashed rgba(167,139,250,0.4); border-radius:5px;
    padding:0.05rem 0.65rem; color:var(--purple); font-size:0.8rem;
    cursor:pointer; transition:all .2s; vertical-align:baseline;
  }
  .select-placeholder:hover { background:rgba(167,139,250,0.18); }
  .select-placeholder.ok  { background:rgba(74,222,128,0.1);  border-color:var(--green); color:var(--green); border-style:solid; }
  .select-placeholder.err { background:rgba(248,113,113,0.1); border-color:var(--red);   color:var(--red);   border-style:solid; }

  .opciones-row {
    display:flex; flex-wrap:wrap; gap:0.55rem;
    padding:0.9rem 1.1rem; border-top:1px solid var(--b0);
    background:rgba(0,0,0,0.15);
  }
  .opcion {
    font-family:var(--mono); font-size:0.8rem; font-weight:600;
    color:var(--purple); background:rgba(167,139,250,0.08);
    border:1px solid rgba(167,139,250,0.25); border-radius:8px;
    padding:0.4rem 1rem; cursor:pointer; transition:all .2s;
  }
  .opcion:hover    { background:rgba(167,139,250,0.18); transform:translateY(-1px); }
  .opcion.selected { background:rgba(167,139,250,0.2);  border-color:var(--purple); }
  .opcion.ok       { background:rgba(74,222,128,0.12);  border-color:var(--green);  color:var(--green); }
  .opcion.err      { background:rgba(248,113,113,0.1);  border-color:var(--red);    color:var(--red); }

  /* ── Ordenar líneas ── */
  .sort-list { padding:0.9rem 1.1rem; display:flex; flex-direction:column; gap:0.4rem; }
  .sort-item {
    display:flex; align-items:center; gap:0.6rem;
    background:rgba(74,222,128,0.05); border:1px solid rgba(74,222,128,0.18);
    border-radius:8px; padding:0.55rem 0.85rem;
    cursor:grab; user-select:none; transition:all .18s;
  }
  .sort-item:hover     { background:rgba(74,222,128,0.1); border-color:rgba(74,222,128,0.35); }
  .sort-item.dragging  { opacity:0.35; transform:scale(0.98); }
  .sort-item.dt        { border-top:2px solid var(--green); }
  .sort-item.db        { border-bottom:2px solid var(--green); }
  .sort-handle         { color:var(--t3); font-size:0.9rem; flex-shrink:0; }
  .sort-code           { font-family:var(--mono); font-size:0.81rem; color:var(--t2); flex:1; }
  .sort-item.ok        { background:rgba(74,222,128,0.1); border-color:rgba(74,222,128,0.5); }
  .sort-item.err       { background:rgba(248,113,113,0.08); border-color:rgba(248,113,113,0.4); }

  /* ── Detectar bug ── */
  .bug-list   { padding:0.65rem 0.85rem; display:flex; flex-direction:column; gap:0.22rem; }
  .bug-line   {
    display:flex; align-items:stretch; border-radius:7px;
    cursor:pointer; transition:all .18s; border:1px solid transparent;
  }
  .bug-line:hover { background:rgba(248,113,113,0.06); border-color:rgba(248,113,113,0.2); }
  .bug-num   {
    font-family:var(--mono); font-size:0.73rem; color:var(--t3);
    min-width:2.4rem; text-align:right; padding:0.48rem 0.7rem 0.48rem 0.4rem;
    user-select:none; flex-shrink:0;
  }
  .bug-code  {
    font-family:var(--mono); font-size:0.83rem; color:var(--t2);
    padding:0.48rem 0.65rem 0.48rem 0; line-height:1.7; flex:1; white-space:pre;
  }
  .bug-line.hi  { background:rgba(248,113,113,0.09); border-color:rgba(248,113,113,0.38); }
  .bug-line.ok  { background:rgba(74,222,128,0.08);  border-color:rgba(74,222,128,0.45); }
  .bug-line.err { background:rgba(248,113,113,0.12); border-color:var(--red); }

  /* ── Sidebar ── */
  .side-panel { display:flex; flex-direction:column; gap:1.1rem; }

  .sc-panel {
    background:var(--card); border:1px solid var(--b0); border-radius:12px; overflow:hidden;
  }
  .sc-hdr {
    padding:0.7rem 1rem; background:rgba(255,255,255,0.022);
    border-bottom:1px solid var(--b0);
    display:flex; align-items:center; gap:0.45rem;
  }
  .sc-title { font-family:var(--mono); font-size:0.68rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--t3); }
  .sc-body  { padding:1rem 1.1rem; }

  /* Navegación — ahora en el top del sidebar */
  .nav-links { display:flex; gap:0.55rem; }
  .nav-links a {
    flex:1; text-align:center;
    font-family:var(--mono); font-size:0.74rem; font-weight:600;
    color:var(--t2); background:rgba(255,255,255,0.03);
    border:1px solid var(--b1); border-radius:8px;
    padding:0.55rem 0.6rem; text-decoration:none; transition:all .2s;
    display:flex; align-items:center; justify-content:center; gap:0.3rem;
  }
  .nav-links a:hover { color:var(--t1); border-color:rgba(255,255,255,0.22); background:rgba(255,255,255,0.06); }

  /* Validar */
  .btn-val {
    width:100%; display:flex; align-items:center; justify-content:center; gap:0.4rem;
    font-family:var(--mono); font-size:0.82rem; font-weight:700;
    color:white; background:var(--blue);
    border:1px solid rgba(59,130,246,0.6); border-radius:9px;
    padding:0.75rem; cursor:pointer; transition:all .2s;
    box-shadow:0 4px 16px rgba(59,130,246,0.2); margin-top:0.8rem;
  }
  .btn-val:hover    { background:#2563eb; }
  .btn-val.ok-state { background:#16a34a; border-color:#15803d; box-shadow:0 4px 16px rgba(74,222,128,0.2); }
  .btn-val.err-state{ background:#991b1b; border-color:#7f1d1d; }

  .feedback {
    border-radius:9px; padding:0.85rem 0.95rem;
    margin-top:0.7rem; font-size:0.83rem; line-height:1.65; display:none;
  }
  .feedback.show { display:block; }
  .fb-ok   { background:rgba(74,222,128,0.07);  border:1px solid rgba(74,222,128,0.28);  color:#86efac; }
  .fb-err  { background:rgba(248,113,113,0.07); border:1px solid rgba(248,113,113,0.28); color:#fca5a5; }
  .fb-icon  { font-size:1rem; margin-bottom:0.25rem; display:block; }
  .fb-title { font-weight:700; color:var(--t1); margin-bottom:0.2rem; font-size:0.86rem; }

  /* Terminal BLE */
  .terminal {
    background:var(--inner); border-radius:7px; padding:0.8rem 0.95rem;
    font-family:var(--mono); font-size:0.78rem; color:var(--t2); line-height:1.8;
    min-height:76px; border:1px solid rgba(255,255,255,0.04);
  }
  .tp{color:var(--green);margin-right:0.35rem;} .tok{color:var(--green);} .terr{color:var(--red);}
  .twarn{color:var(--yellow);} .tinfo{color:var(--blue-l);} .tdim{color:var(--t3);}

  .ble-row { display:flex; gap:0.55rem; margin-top:0.8rem; flex-wrap:wrap; }
  .btn-ble {
    display:inline-flex; align-items:center; gap:0.35rem;
    font-family:var(--mono); font-size:0.76rem; font-weight:600;
    border-radius:8px; padding:0.5rem 1rem; border:1px solid; cursor:pointer; transition:all .2s;
  }
  .btn-ghost { color:var(--t2); background:rgba(255,255,255,0.04); border-color:var(--b1); }
  .btn-ghost:hover { background:rgba(255,255,255,0.09); color:var(--t1); }
  .btn-run {
    color:white; background:var(--blue); border-color:rgba(59,130,246,0.6);
    box-shadow:0 4px 14px rgba(59,130,246,0.22); flex:1; justify-content:center;
  }
  .btn-run:hover:not(:disabled) { background:#2563eb; }
  .btn-run:disabled { opacity:0.35; cursor:not-allowed; }

  /* Hint */
  .hint-box {
    background:rgba(250,204,21,0.05); border:1px solid rgba(250,204,21,0.2); border-radius:9px;
    padding:0.8rem 0.95rem;
  }
  .hint-lbl { font-family:var(--mono); font-size:0.62rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--yellow); margin-bottom:0.28rem; }
  .hint-txt { font-size:0.82rem; color:#fde68a; line-height:1.65; }

  @media (max-width:899px) { .ex-header { grid-column:1; } }
</style>

