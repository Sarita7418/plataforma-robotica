<!-- ═══ GRID ════════════════════════════════════════════════════════════════ -->
<div class="page-grid">

  <!-- ── Header ── -->
  <div class="ex-header">
    <div class="ex-badges">
      {tema    && <span class="badge badge-mod">Módulo {tema.orden} · {tema.titulo}</span>}
      {subtema && <span class="badge badge-sub">{subtema.titulo}</span>}
      <span class={`badge badge-${meta.color}`}>{meta.icon} {meta.label}</span>
    </div>
    <h1 class="ex-title">{ejercicio.titulo}</h1>
    <div class="ex-mision">
      <span class="ex-mision-icon">🎯</span>
      <div>
        <div class="mision-label">Misión</div>
        <p class="mision-text">{ejercicio.mision}</p>
      </div>
    </div>
  </div>

  <!-- ══ COLUMNA IZQUIERDA: panel de ejercicio ══ -->
  <div>

    <!-- COMPLETAR ESPACIOS -->
    {tipo === 'completar_espacios' && (
      <div class="panel">
        <div class="panel-hdr">
          <span class="panel-lang">C++ · Completa el espacio</span>
          <div class="dots"><div class="dot dr"></div><div class="dot dy"></div><div class="dot dg"></div></div>
        </div>
        <div class="code-body" set:html={buildCompletarHTML(cfg.codigo_base ?? '')} />
      </div>
    )}

    <!-- ARRASTRAR BLOQUES -->
    {tipo === 'arrastrar_bloques' && (
      <div class="panel" id="panel-drag">
        <div class="panel-hdr">
          <span class="panel-lang">C++ · Arrastra los bloques</span>
          <div class="dots"><div class="dot dr"></div><div class="dot dy"></div><div class="dot dg"></div></div>
        </div>
        <div class="code-body" id="code-drag" set:html={buildArrastrarHTML(cfg.codigo_base ?? '')} />
        <div class="blocks-palette" id="palette">
          {(cfg.bloques_disponibles ?? []).map((b: string, i: number) => (
            <div class="chip" draggable="true" data-block={b} id={`chip-${i}`}>{b}</div>
          ))}
        </div>
      </div>
    )}

    <!-- SELECCIÓN MÚLTIPLE -->
    {tipo === 'seleccion_multiple' && (
      <div class="panel">
        <div class="panel-hdr">
          <span class="panel-lang">C++ · Selección múltiple</span>
          <div class="dots"><div class="dot dr"></div><div class="dot dy"></div><div class="dot dg"></div></div>
        </div>
        <div class="code-body" set:html={buildSeleccionHTML(cfg.codigo_base ?? '')} />
        <div class="opciones-row">
          {(cfg.opciones ?? []).map((op: string, i: number) => (
            <button class="opcion" data-idx={i}>{op}</button>
          ))}
        </div>
      </div>
    )}

    <!-- ORDENAR LÍNEAS -->
    {tipo === 'ordenar_lineas' && (
      <div class="panel">
        <div class="panel-hdr">
          <span class="panel-lang">C++ · Ordena las líneas</span>
          <div class="dots"><div class="dot dr"></div><div class="dot dy"></div><div class="dot dg"></div></div>
        </div>
        <div class="sort-list" id="sort-list">
          {(cfg.lineas_desordenadas ?? []).map((linea: string) => (
            <div class="sort-item" draggable="true" data-linea={linea}>
              <span class="sort-handle">⠿</span>
              <span class="sort-code" set:html={syn(esc(linea))} />
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- DETECTAR BUG -->
    {tipo === 'detectar_bug' && (
      <div class="panel">
        <div class="panel-hdr">
          <span class="panel-lang">C++ · Encuentra el bug</span>
          <div class="dots"><div class="dot dr"></div><div class="dot dy"></div><div class="dot dg"></div></div>
        </div>
        <div class="bug-list" id="bug-list">
          {(cfg.codigo_completo ?? []).map((linea: string, i: number) => (
            <div class="bug-line" data-idx={i}>
              <span class="bug-num">{i + 1}</span>
              <span class="bug-code" set:html={syn(esc(linea))} />
            </div>
          ))}
        </div>
      </div>
    )}

  </div>

  <!-- ══ SIDEBAR ══ -->
  <div class="side-panel">

    <!-- 1. NAVEGACIÓN (arriba de todo) -->
    <div class="sc-panel">
      <div class="sc-hdr"><span class="sc-title">Navegación</span></div>
      <div class="sc-body">
        <div class="nav-links">
          <a href="/">← Menú</a>
          {tema && <a href={`/teoria/${tema.id}`}>📖 Teoría</a>}
        </div>
      </div>
    </div>

    <!-- 2. INSTRUCCIONES + VALIDAR -->
    <div class="sc-panel">
      <div class="sc-hdr">
        <span style="font-size:1rem;">{meta.icon}</span>
        <span class="sc-title">Cómo resolver</span>
      </div>
      <div class="sc-body">
        <p style="font-size:0.84rem;color:var(--t2);line-height:1.65;">{meta.desc}</p>
        <button class="btn-val" id="btn-val">Verificar respuesta ✓</button>
        <div class="feedback" id="feedback">
          <span class="fb-icon" id="fb-icon"></span>
          <div class="fb-title" id="fb-title"></div>
          <div id="fb-msg"></div>
        </div>
      </div>
    </div>

    <!-- 3. ROBOT BLE -->
    <div class="sc-panel">
      <div class="sc-hdr"><span class="sc-title">🤖 Robot BLE</span></div>
      <div class="sc-body">
        <div class="terminal" id="terminal">
          <span class="tdim"><span class="tp">~</span>Esperando conexión BLE...</span>
        </div>
        <div class="ble-row">
          <button class="btn-ble btn-ghost" id="btn-conectar">📡 Vincular</button>
          <button class="btn-ble btn-run"   id="btn-run" disabled>▶ Ejecutar</button>
        </div>
      </div>
    </div>

    <!-- 4. EXPLICACIÓN BUG (oculta hasta acertar) -->
    {cfg.explicacion_bug && (
      <div class="sc-panel" id="hint-panel" style="display:none;">
        <div class="sc-hdr"><span class="sc-title">💡 Explicación del bug</span></div>
        <div class="sc-body">
          <div class="hint-box">
            <div class="hint-lbl">¿Por qué es un error?</div>
            <p class="hint-txt">{cfg.explicacion_bug}</p>
          </div>
        </div>
      </div>
    )}

  </div>
</div>

<!-- ═══ CLIENT SCRIPT ══════════════════════════════════════════════════════ -->
<script define:vars={{ cfgJSON, tipoStr, cmdEsperado: ejercicio.comando_esperado }}>

const cfg  = JSON.parse(cfgJSON);
const tipo = tipoStr;

// ── Estado ────────────────────────────────────────────────────────────────────
let bleDevice     = null;
let selOpcion     = null;          // seleccion_multiple: índice elegido
let dropState     = {};            // arrastrar: { "1": valor, "2": valor, … }
let dragChip      = null;          // chip que se está arrastrando
let bugSel        = null;          // detectar_bug: índice de línea clicada

// ── Init ──────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  if (tipo === 'arrastrar_bloques')  initDrag();
  if (tipo === 'ordenar_lineas')     initSort();
  if (tipo === 'seleccion_multiple') initSelect();
  if (tipo === 'detectar_bug')       initBug();
});

// ══════════════════════════════════════════════════════════════════════════════
// 1. COMPLETAR ESPACIOS — sólo necesitamos leer el input
// ══════════════════════════════════════════════════════════════════════════════
function getCompletarVal() {
  const el = document.getElementById('inp-completar');
  return el ? el.value.trim() : '';
}

// ══════════════════════════════════════════════════════════════════════════════
// 2. ARRASTRAR BLOQUES
// ══════════════════════════════════════════════════════════════════════════════
function initDrag() {
  // Chips → dragstart
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('dragstart', e => {
      dragChip = chip;
      e.dataTransfer.setData('text/plain', chip.dataset.block);
      e.dataTransfer.effectAllowed = 'move';
    });
    chip.addEventListener('dragend', () => {
      // si no se soltó en ninguna zona válida, no hacer nada
      dragChip = null;
    });
  });

  // Drop-zones → dragover + dragleave + drop
  document.querySelectorAll('.drop-zone').forEach(zone => {
    zone.addEventListener('dragover', e => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      zone.classList.add('over');
    });
    zone.addEventListener('dragleave', () => zone.classList.remove('over'));
    zone.addEventListener('drop', e => {
      e.preventDefault();
      zone.classList.remove('over');
      const val = e.dataTransfer.getData('text/plain');
      if (!val) return;

      // Si la zona ya tenía un valor, devolver el chip anterior
      const prevVal = dropState[zone.dataset.drop];
      if (prevVal) {
        document.querySelectorAll('.chip').forEach(c => {
          if (c.dataset.block === prevVal) c.classList.remove('used');
        });
      }

      dropState[zone.dataset.drop] = val;
      zone.textContent = val;
      zone.classList.remove('err', 'ok');
      zone.classList.add('filled');

      // Marcar chip como usado
      if (dragChip) { dragChip.classList.add('used'); dragChip = null; }
    });
  });
}

function validateDrag() {
  const sol = cfg.solucion_esperada ?? {};
  let allOk = true;
  let allFilled = true;
  document.querySelectorAll('.drop-zone').forEach(zone => {
    const key = `___DROP_${zone.dataset.drop}___`;
    const actual   = dropState[zone.dataset.drop];
    const expected = sol[key];
    if (!actual) { allFilled = false; return; }
    zone.classList.remove('ok','err','filled');
    if (actual === expected) { zone.classList.add('ok'); }
    else                     { zone.classList.add('err'); allOk = false; }
  });
  return allFilled && allOk;
}

// ══════════════════════════════════════════════════════════════════════════════
// 3. SELECCIÓN MÚLTIPLE
// ══════════════════════════════════════════════════════════════════════════════
function initSelect() {
  document.querySelectorAll('.opcion').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.idx);
      selOpcion = idx;
      const val = btn.textContent;
      document.querySelectorAll('.opcion').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      const ph = document.getElementById('select-chosen');
      if (ph) ph.textContent = val;
    });
  });
}

function validateSelect() {
  const correcto = cfg.indice_correcto ?? 0;
  const ok = selOpcion === correcto;
  document.querySelectorAll('.opcion').forEach((b, i) => {
    b.classList.remove('ok','err','selected');
    if (i === correcto)                   b.classList.add('ok');
    else if (i === selOpcion && !ok)      b.classList.add('err');
  });
  const ph = document.getElementById('select-chosen');
  if (ph) {
    ph.classList.remove('ok','err');
    ph.classList.add(ok ? 'ok' : (selOpcion !== null ? 'err' : ''));
  }
  return ok;
}

// ══════════════════════════════════════════════════════════════════════════════
// 4. ORDENAR LÍNEAS
// ══════════════════════════════════════════════════════════════════════════════
function initSort() {
  const list = document.getElementById('sort-list');
  if (!list) return;
  let src = null;

  list.addEventListener('dragstart', e => {
    src = e.target.closest('.sort-item');
    if (src) { src.classList.add('dragging'); e.dataTransfer.effectAllowed = 'move'; }
  });
  list.addEventListener('dragend', () => {
    document.querySelectorAll('.sort-item').forEach(el =>
      el.classList.remove('dragging','dt','db'));
    src = null;
  });
  list.addEventListener('dragover', e => {
    e.preventDefault();
    const target = e.target.closest('.sort-item');
    if (!target || target === src) return;
    document.querySelectorAll('.sort-item').forEach(el => el.classList.remove('dt','db'));
    const mid = target.getBoundingClientRect().top + target.offsetHeight / 2;
    target.classList.add(e.clientY < mid ? 'dt' : 'db');
  });
  list.addEventListener('drop', e => {
    e.preventDefault();
    const target = e.target.closest('.sort-item');
    if (!target || !src || target === src) return;
    const before = target.classList.contains('dt');
    list.insertBefore(src, before ? target : target.nextSibling);
  });
}

function validateSort() {
  const correct = cfg.orden_correcto ?? [];
  const items   = [...document.querySelectorAll('.sort-item')];
  const current = items.map(el => el.dataset.linea);
  const ok = current.every((l, i) => l === correct[i]);
  items.forEach((el, i) => {
    el.classList.remove('ok','err');
    el.classList.add(el.dataset.linea === correct[i] ? 'ok' : 'err');
  });
  return ok;
}

// ══════════════════════════════════════════════════════════════════════════════
// 5. DETECTAR BUG
// ══════════════════════════════════════════════════════════════════════════════
function initBug() {
  document.querySelectorAll('.bug-line').forEach(line => {
    line.addEventListener('click', () => {
      bugSel = parseInt(line.dataset.idx);
      document.querySelectorAll('.bug-line').forEach(l => l.classList.remove('hi','ok','err'));
      line.classList.add('hi');
    });
  });
}

function validateBug() {
  const correcto = cfg.linea_con_error ?? 0;
  const ok = bugSel === correcto;
  document.querySelectorAll('.bug-line').forEach((el, i) => {
    el.classList.remove('hi','ok','err');
    if (i === correcto)             el.classList.add('ok');
    else if (i === bugSel && !ok)   el.classList.add('err');
  });
  if (ok) {
    const hint = document.getElementById('hint-panel');
    if (hint) hint.style.display = 'block';
  }
  return ok;
}

// ══════════════════════════════════════════════════════════════════════════════
// VALIDAR CENTRAL
// ══════════════════════════════════════════════════════════════════════════════
document.getElementById('btn-val')?.addEventListener('click', () => {
  let ok = false;
  if      (tipo === 'completar_espacios') ok = getCompletarVal() === (cfg.respuesta_correcta ?? '');
  else if (tipo === 'arrastrar_bloques')  ok = validateDrag();
  else if (tipo === 'seleccion_multiple') ok = validateSelect();
  else if (tipo === 'ordenar_lineas')     ok = validateSort();
  else if (tipo === 'detectar_bug')       ok = validateBug();

  // Feedback visual en input de completar
  if (tipo === 'completar_espacios') {
    const inp = document.getElementById('inp-completar');
    if (inp) { inp.classList.toggle('ok', ok); inp.classList.toggle('err', !ok); }
  }

  const fb    = document.getElementById('feedback');
  const ficon = document.getElementById('fb-icon');
  const ftit  = document.getElementById('fb-title');
  const fmsg  = document.getElementById('fb-msg');
  const btnV  = document.getElementById('btn-val');

  fb.className    = 'feedback show ' + (ok ? 'fb-ok' : 'fb-err');
  ficon.textContent = ok ? '✅' : '❌';
  ftit.textContent  = ok ? '¡Correcto! Excelente trabajo.' : 'Casi… sigue intentando.';
  fmsg.textContent  = ok
    ? 'Solución válida. Puedes ejecutarla en el robot o avanzar al siguiente ejercicio.'
    : 'Revisa tu respuesta con cuidado. ¡Cada error es parte del aprendizaje!';

  btnV.className   = 'btn-val ' + (ok ? 'ok-state' : 'err-state');
  btnV.textContent = ok ? '✓ ¡Correcto!' : '✗ Reintentar';

  if (ok) {
    const t = document.getElementById('terminal');
    if (t && !bleDevice) t.innerHTML = `<span class="tok">✔</span> <span class="tdim">Solución válida — conecta el robot para ejecutar.</span>`;
    setTimeout(() => {
      btnV.className   = 'btn-val';
      btnV.textContent = 'Verificar respuesta ✓';
    }, 3500);
  }
});

// ══════════════════════════════════════════════════════════════════════════════
// BLE
// ══════════════════════════════════════════════════════════════════════════════
document.getElementById('btn-conectar')?.addEventListener('click', async () => {
  const t   = document.getElementById('terminal');
  const run = document.getElementById('btn-run');
  try {
    t.innerHTML = `<span class="tinfo">◌</span> <span class="tdim">Buscando dispositivo BLE...</span>`;
    bleDevice = await navigator.bluetooth.requestDevice({ acceptAllDevices: true });
    t.innerHTML = `<span class="tok">✔</span> Conectado a <strong style="color:var(--t1)">${bleDevice.name}</strong>`;
    if (run) run.disabled = false;
  } catch (err) {
    t.innerHTML = `<span class="terr">✖</span> ${err.message}`;
    bleDevice = null;
  }
});

document.getElementById('btn-run')?.addEventListener('click', () => {
  const t = document.getElementById('terminal');
  t.innerHTML = `<span class="tok">▶</span> Enviando: <strong style="color:var(--t1)">${cmdEsperado}</strong>`;
});
</script>
</Layout>