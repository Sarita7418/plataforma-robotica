---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase.js';

const { data: temas } = await supabase.from('temas').select('*').order('orden', { ascending: true });
const { data: ejercicios } = await supabase.from('ejercicios').select('*').order('orden', { ascending: true });
---
<Layout title="Menú Principal">
  <main class="max-w-6xl mx-auto p-6 mt-8">
    <header class="mb-10 text-center">
      <h1 class="text-4xl font-extrabold text-slate-100 mb-4">Lógica de <span class="text-blue-500">Programación</span></h1>
      <p class="text-lg text-slate-400">Selecciona un módulo para estudiar la teoría y aplicar debugging físico.</p>
    </header>

    <div class="space-y-8">
      {temas && temas.map((tema) => (
        <section class="bg-slate-800/50 p-6 sm:p-8 rounded-xl shadow-lg border border-slate-700/50 backdrop-blur-sm">
          
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8 border-b border-slate-700 pb-6">
            <div>
              <div class="flex items-center gap-3 mb-2">
                <span class="bg-blue-500/10 text-blue-400 text-xs font-bold px-3 py-1 rounded border border-blue-500/20">Módulo {tema.orden}</span>
                <h2 class="text-2xl font-bold text-slate-200">{tema.titulo}</h2>
              </div>
              <p class="text-slate-400">{tema.descripcion}</p>
            </div>
            
            <a href={`/teoria/${tema.id}`} class="shrink-0 flex items-center justify-center gap-2 bg-blue-600/10 text-blue-400 hover:bg-blue-600 hover:text-white border border-blue-500/50 px-5 py-3 rounded-lg font-bold transition-all shadow-md group">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
              Aprender Teoría
            </a>
          </div>
          
          <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-4">Ejercicios Prácticos:</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {ejercicios && ejercicios.filter(ej => ej.tema_id === tema.id).map((ejercicio) => (
              <a href={`/ejercicio/${ejercicio.id}`} class="block bg-slate-900/80 p-5 rounded-lg border border-slate-700 hover:border-blue-500 hover:bg-slate-800 transition-all group shadow-md">
                <h4 class="font-bold text-slate-200 mb-2 group-hover:text-blue-400 transition-colors">{ejercicio.titulo}</h4>
                <p class="text-sm text-slate-500 line-clamp-2">{ejercicio.mision}</p>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>
</Layout>